{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:4200" ]
  },
  "RabbitMq": {
    "RetryCount": 3,
    "RetryIntervalMs": 1000
  },
  "InternalAuth": {
    "SharedKey": "dev-internal-shared-key"
  }
}
