{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "Finance": {
    "Messaging": {
      "Enabled": false
    },
    "LeaseGateway": {
      "UseStub": true,
      "Stub": {
        "Status": "active",
        "PrimaryResidentUserId": null,
        "LeaseIdsForUser": []
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
