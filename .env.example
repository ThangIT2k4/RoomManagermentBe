# Sao chép thành `.env` (file `.env` không được commit). Chỉ điền giá trị thật trên máy bạn / CI bảo mật.
# Không đặt mật khẩu, khóa API hay connection string đầy đủ trong repo hoặc trong appsettings.json.

# --- Postgres (bắt buộc điền khi chạy Docker) ---
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

AUTH_DB=
FINANCE_DB=
NOTIFICATION_DB=

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=
RABBITMQ_HOST=rabbitmq

# --- API ports (Gateway 5000, Notification 5001, sau đó tăng dần) ---
GATEWAY_API_PORT=5000
NOTIFICATION_API_PORT=5001
AUTH_API_PORT=5002
FINANCE_API_PORT=5003
EXTERNAL_API_PORT=5004

# --- Connection strings (chỉ trong .env / user-secrets / biến môi trường) ---
AUTH_CONNECTION_STRING=
FINANCE_CONNECTION_STRING=
NOTIFICATION_CONNECTION_STRING=

# --- Gateway → backend (Docker) ---
AUTH_API_URL=http://auth-api:${AUTH_API_PORT}
FINANCE_API_URL=http://finance-api:${FINANCE_API_PORT}
EXTERNAL_API_URL=http://external-api:${EXTERNAL_API_PORT}
NOTIFICATION_API_URL=http://notification-api:${NOTIFICATION_API_PORT}

# --- Identity (legacy, đã tắt trong compose) ---
# IDENTITY_API_PORT=
# IDENTITY_CONNECTION_STRING=
# IDENTITY_API_URL=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=5000
REDIS_INSTANCE_NAME=RoomManagermentGateway:

# --- Misc ---
ASPNETCORE_ENVIRONMENT=Development
SESSION_TIMEOUT_MINUTES=30
SESSION_COOKIE_NAME=RoomManager.SessionId
LOG_BASE_PATH=/app/logs
GATEWAY_MAX_REQUEST_BODY_SIZE=10485760

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Khóa nội bộ Gateway ↔ Notification (đặt cùng giá trị ở cả hai phía qua env / user-secrets) ---
# INTERNAL_AUTH_SHARED_KEY=
