{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },
      "finance": {
        "ClusterId": "finance",
        "Match": { "Path": "/finance/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/finance" }
        ]
      },
      "external": {
        "ClusterId": "external",
        "Match": { "Path": "/external/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/external" }
        ]
      },
      "notification": {
        "ClusterId": "notification",
        "Match": { "Path": "/notification/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/notification" }
        ]
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5002" }
        }
      },
      "finance": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5003" }
        }
      },
      "external": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5004" }
        }
      },
      "notification": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5001" }
        }
      }
    }
  },
  "RateLimiting": {
    "Policies": {
      "default": {
        "PermitLimit": 100,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "login": {
        "PermitLimit": 100,
        "WindowSeconds": 60,
        "QueueLimit": 2
      },
      "register": {
        "PermitLimit": 100,
        "WindowSeconds": 60,
        "QueueLimit": 1
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5000",
      "https://localhost:5000"
    ]
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "Kestrel": {
    "MaxRequestBodySize": 10485760
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "InstanceName": "RoomManagermentGateway:"
  },
  "Session": {
    "TimeoutMinutes": 30,
    "Cookie": {
      "Name": "RoomManager.SessionId"
    }
  },
  "InternalAuth": {
    "SharedKey": ""
  }
}
