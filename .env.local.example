# Local Docker defaults
# Copy to .env.local and customize if needed.

POSTGRES_DB=roommanager
POSTGRES_USER=roommanager
POSTGRES_PASSWORD=roommanager

AUTH_DB=roommanager_auth
FINANCE_DB=roommanager_finance
NOTIFICATION_DB=roommanager_notification
CRM_DB=roommanager_crm
PROPERTY_DB=roommanager_property
LEASE_DB=roommanager_lease
ORGANIZATION_DB=roommanager_organization

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

GATEWAY_API_PORT=5000
NOTIFICATION_API_PORT=5001
AUTH_API_PORT=5002
FINANCE_API_PORT=5003
EXTERNAL_API_PORT=5004
CRM_API_PORT=5005
PROPERTY_API_PORT=5007
LEASE_API_PORT=5008
ORGANIZATION_API_PORT=5014

AUTH_CONNECTION_STRING=Host=postgres;Port=5432;Database=${AUTH_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
FINANCE_CONNECTION_STRING=Host=postgres;Port=5432;Database=${FINANCE_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
NOTIFICATION_CONNECTION_STRING=Host=postgres;Port=5432;Database=${NOTIFICATION_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
CRM_CONNECTION_STRING=Host=postgres;Port=5432;Database=${CRM_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
PROPERTY_CONNECTION_STRING=Host=postgres;Port=5432;Database=${PROPERTY_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
LEASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=${LEASE_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
ORGANIZATION_CONNECTION_STRING=Host=postgres;Port=5432;Database=${ORGANIZATION_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

AUTH_API_URL=http://auth-api:${AUTH_API_PORT}
FINANCE_API_URL=http://finance-api:${FINANCE_API_PORT}
EXTERNAL_API_URL=http://external-api:${EXTERNAL_API_PORT}
NOTIFICATION_API_URL=http://notification-api:${NOTIFICATION_API_PORT}
CRM_API_URL=http://crm-api:${CRM_API_PORT}
PROPERTY_API_URL=http://property-api:${PROPERTY_API_PORT}
LEASE_API_URL=http://lease-api:${LEASE_API_PORT}
ORGANIZATION_API_URL=http://organization-api:${ORGANIZATION_API_PORT}

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=5000
REDIS_CONFIGURATION=redis:6379
REDIS_INSTANCE_NAME=RoomManagermentGateway:

ASPNETCORE_ENVIRONMENT=Development
SESSION_TIMEOUT_MINUTES=30
SESSION_COOKIE_NAME=RoomManager.SessionId
LOG_BASE_PATH=/app/logs
GATEWAY_MAX_REQUEST_BODY_SIZE=10485760
FINANCE_MESSAGING_ENABLED=true

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=kimluan2k4it@gmail.com
EMAIL_PASSWORD=replace-with-app-password
EMAIL_ENABLE_SSL=true
EMAIL_FROM_EMAIL=kimluan2k4it@gmail.com
EMAIL_FROM_NAME=RoomManagerment Zoro

OTP_RESEND_COOLDOWN_MINUTES=2
OTP_VERIFY_EMAIL_EXPIRY_MINUTES=5
OTP_RESET_PASSWORD_EXPIRY_MINUTES=15

NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

INTERNAL_AUTH_SHARED_KEY=replace-with-strong-key
