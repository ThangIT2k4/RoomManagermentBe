# Production template — Postgres (Azure), Redis, RabbitMQ đều EXTERNAL.
# Copy sang .env.production và điền giá trị thật. KHÔNG commit .env.production vào git.

# =============================================================================
# POSTGRES (Azure) — dùng full connection string cho từng module
# Format: Host=<server>.postgres.database.azure.com;Port=5432;Database=<db>;
#         Username=<user>;Password=<pass>;Ssl Mode=Require;Trust Server Certificate=true
# =============================================================================
AUTH_CONNECTION_STRING=
FINANCE_CONNECTION_STRING=
NOTIFICATION_CONNECTION_STRING=
CRM_CONNECTION_STRING=
PROPERTY_CONNECTION_STRING=
LEASE_CONNECTION_STRING=
ORGANIZATION_CONNECTION_STRING=

# =============================================================================
# REDIS (external droplet)
# Format StackExchange.Redis: <HOST>:6379,password=<PASS>,abortConnect=false,
#        connectTimeout=5000,syncTimeout=5000
# =============================================================================
REDIS_CONFIGURATION=
REDIS_INSTANCE_NAME=RoomManagermentGateway:

# =============================================================================
# RABBITMQ (external droplet)
# =============================================================================
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=
RABBITMQ_VHOST=/

# =============================================================================
# API ports
# =============================================================================
GATEWAY_API_PORT=5000
NOTIFICATION_API_PORT=5001
AUTH_API_PORT=5002
FINANCE_API_PORT=5003
EXTERNAL_API_PORT=5004
CRM_API_PORT=5005
PROPERTY_API_PORT=5007
LEASE_API_PORT=5008
ORGANIZATION_API_PORT=5014

# Gateway → backend (dùng docker service name vì cùng network)
AUTH_API_URL=http://auth-api:5002
FINANCE_API_URL=http://finance-api:5003
EXTERNAL_API_URL=http://external-api:5004
NOTIFICATION_API_URL=http://notification-api:5001
CRM_API_URL=http://crm-api:5005
PROPERTY_API_URL=http://property-api:5007
LEASE_API_URL=http://lease-api:5008
ORGANIZATION_API_URL=http://organization-api:5014

# =============================================================================
# App
# =============================================================================
ASPNETCORE_ENVIRONMENT=Production
SESSION_TIMEOUT_MINUTES=30
SESSION_COOKIE_NAME=RoomManager.SessionId
LOG_BASE_PATH=/app/logs
FINANCE_MESSAGING_ENABLED=true
INTERNAL_AUTH_SHARED_KEY=

# =============================================================================
# EMAIL (OTP)
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_ENABLE_SSL=true
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=RoomManagerment Zoro

OTP_RESEND_COOLDOWN_MINUTES=2
OTP_VERIFY_EMAIL_EXPIRY_MINUTES=5
OTP_RESET_PASSWORD_EXPIRY_MINUTES=15

# =============================================================================
# Nginx
# =============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=4096
NGINX_LOG_LEVEL=warn
NGINX_GZIP_ENABLED=on
NGINX_RATE_LIMIT=10r/s
NGINX_CLIENT_MAX_BODY_SIZE=50M
