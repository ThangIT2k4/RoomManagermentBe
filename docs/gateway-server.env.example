# =============================================================================
# Gateway — biến môi trường cho server (systemd / docker run --env-file)
# =============================================================================
# Cách dùng:
#   1) sudo cp gateway-server.env.example /etc/roommanager/gateway.env
#   2) sudo nano /etc/roommanager/gateway.env  → điền giá trị thật
#   3) sudo chmod 600 /etc/roommanager/gateway.env
#  4) Trong unit systemd (ví dụ /etc/systemd/system/myapp.service):
#        WorkingDirectory=/var/www/myapp
#        ExecStart=/usr/bin/dotnet /var/www/myapp/RoomManagerment.Gateway.dll
#        EnvironmentFile=/etc/roommanager/gateway.env
#   5) sudo mkdir -p /var/log/roommanager/gateway && sudo chown <user-service>:...
#
# Lưu ý: không có khoảng trắng quanh dấu = . Giá trị có ký tự đặc biệt có thể cần bọc ngoặc kép.
#
# CI (.github/workflows/deploy.yml) copy lần lượt vào:
#   Gateway /var/www/myapp  |  Auth /var/www/auth-api  |  Finance /var/www/finance-api
#   External /var/www/external-api  |  Notification /var/www/notification-api
# Mỗi API cần unit systemd riêng (ASPNETCORE_URLS đúng port khớp ReverseProxy bên dưới).
# =============================================================================

# --- Bắt buộc / nên có ---
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5000

# Redis (cache + SignalR backplane). Ví dụ có password:
# Redis__Configuration=your-redis-host:6379,password=YOUR_PASSWORD,abortConnect=false,connectTimeout=5000
Redis__Configuration=127.0.0.1:6379
Redis__InstanceName=RoomManagermentGateway:
ConnectionStrings__Redis=127.0.0.1:6379

# --- YARP: trỏ tới API thật trên server (sửa host/port cho đúng) ---
ReverseProxy__Clusters__auth__Destinations__d1__Address=http://127.0.0.1:5002
ReverseProxy__Clusters__finance__Destinations__d1__Address=http://127.0.0.1:5003
ReverseProxy__Clusters__external__Destinations__d1__Address=http://127.0.0.1:5004
ReverseProxy__Clusters__notification__Destinations__d1__Address=http://127.0.0.1:5001

# --- CORS: domain frontend production (thêm dòng __1, __2 nếu nhiều domain) ---
Cors__AllowedOrigins__0=https://your-frontend.example.com

# --- Khóa nội bộ gửi kèm request tới Notification (để trống nếu không dùng; phải khớp phía Notification API) ---
InternalAuth__SharedKey=

# --- Log (thư mục phải tồn tại và user chạy service có quyền ghi) ---
LOG_BASE_PATH=/var/log/roommanager

# --- Tuỳ chọn ---
Session__TimeoutMinutes=30
# Kestrel__MaxRequestBodySize=10485760

# =============================================================================
# Gợi ý thêm (chỉ khi cần tinh chỉnh log)
# =============================================================================
# Logging__LogLevel__Default=Information
# Logging__LogLevel__Microsoft.AspNetCore=Warning
